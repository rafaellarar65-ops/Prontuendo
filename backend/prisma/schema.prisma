generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  MEDICO
  RECEPCAO
  PATIENT
}

enum ConsultationStatus {
  DRAFT
  FINALIZED
}

enum PrescriptionStatus {
  RASCUNHO
  ATIVA
  CANCELADA
  VENCIDA
}

enum AppointmentType {
  PRIMEIRA_CONSULTA
  RETORNO
  TELECONSULTA
  EXAME
}

enum AppointmentStatus {
  AGENDADO
  CONFIRMADO
  EM_ANDAMENTO
  CONCLUIDO
  CANCELADO
}

model Tenant {
  id                String             @id @default(cuid())
  name              String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  users             User[]
  patients          Patient[]
  activityLogs      ActivityLog[]
  consultations     Consultation[]
  glucoseLogs       GlucoseLog[]
  labResults        LabResult[]
  bioimpedanceExams BioimpedanceExam[]
  prescriptions     Prescription[]
  medications       Medication[]
  drugTemplates     DrugTemplate[]
  clinicalScores    ClinicalScore[]
  appointments      Appointment[]
  documents         Document[]
}

model User {
  id            String         @id @default(cuid())
  tenantId      String
  email         String
  passwordHash  String
  fullName      String
  role          Role
  patientLinkId String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  patientLink   Patient?       @relation(fields: [patientLinkId], references: [id])
  refreshTokens RefreshToken[]

  @@unique([tenantId, email])
  @@unique([id, tenantId])
  @@index([tenantId, role])
}

model Patient {
  id                String             @id @default(cuid())
  tenantId          String
  fullName          String
  cpf               String?
  birthDate         DateTime?
  sex               String?            @default("NI")
  phone             String?
  email             String?
  address           String?
  notes             String?
  tags              String[]
  lifecycle         String             @default("ACTIVE")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  portalUsers       User[]
  consultations     Consultation[]
  glucoseLogs       GlucoseLog[]
  labResults        LabResult[]
  bioimpedanceExams BioimpedanceExam[]
  prescriptions     Prescription[]
  clinicalScores    ClinicalScore[]
  appointments      Appointment[]
  documents         Document[]

  @@unique([id, tenantId])
  @@index([tenantId, fullName])
  @@index([tenantId, lifecycle])
}

model ClinicalScore {
  id           String   @id @default(cuid())
  tenantId     String
  patientId    String
  scoreType    String
  inputs       Json
  result       Json
  calculatedAt DateTime @default(now())
  clinicianId  String?
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  patient      Patient  @relation(fields: [patientId], references: [id])

  @@index([tenantId, patientId, scoreType])
  @@index([tenantId, patientId, calculatedAt])
}

model RefreshToken {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId, expiresAt])
}

model ActivityLog {
  id        String   @id @default(cuid())
  tenantId  String
  actorId   String
  action    String
  resource  String
  metadata  Json?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
}

model Consultation {
  id            String                @id @default(cuid())
  tenantId      String
  patientId     String
  clinicianId   String
  status        ConsultationStatus    @default(DRAFT)
  latestDraft   Json?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  finalizedAt   DateTime?
  patient       Patient               @relation(fields: [patientId], references: [id])
  tenant        Tenant                @relation(fields: [tenantId], references: [id])
  versions      ConsultationVersion[]
  prescriptions Prescription[]
  documents     Document[]

  @@unique([id, tenantId])
  @@index([tenantId, patientId, status])
  @@index([tenantId, updatedAt])
}

model Document {
  id             String        @id @default(cuid())
  tenantId       String
  patientId      String
  consultationId String?
  category       String
  fileName       String
  filePath       String
  mimeType       String
  isFromPortal   Boolean       @default(false)
  createdBy      String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  patient        Patient       @relation(fields: [patientId], references: [id])
  consultation   Consultation? @relation(fields: [consultationId], references: [id], onDelete: SetNull)

  @@index([tenantId, patientId, createdAt])
  @@index([tenantId, consultationId])
  @@index([tenantId, category])
}

model Prescription {
  id             String             @id @default(cuid())
  tenantId       String
  patientId      String
  consultationId String?
  clinicianId    String
  status         PrescriptionStatus @default(RASCUNHO)
  validUntil     DateTime?
  notes          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  tenant         Tenant             @relation(fields: [tenantId], references: [id])
  patient        Patient            @relation(fields: [patientId], references: [id])
  consultation   Consultation?      @relation(fields: [consultationId], references: [id])
  items          PrescriptionItem[]

  @@index([tenantId, patientId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, consultationId])
}

model PrescriptionItem {
  id             String       @id @default(cuid())
  prescriptionId String
  medicationName String
  dosage         String
  frequency      String
  route          String?
  duration       String?
  instructions   String?
  quantity       Float?
  unit           String?
  sortOrder      Int
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@index([prescriptionId, sortOrder])
}

model Medication {
  id               String  @id @default(cuid())
  tenantId         String
  name             String
  activeIngredient String?
  presentation     String?
  category         String?
  isControlled     Boolean @default(false)
  tenant           Tenant  @relation(fields: [tenantId], references: [id])

  @@index([tenantId, name])
  @@index([tenantId, category])
}

model DrugTemplate {
  id           String   @id @default(cuid())
  tenantId     String
  genericName  String
  brandName    String?
  class        String
  defaultDose  String
  defaultRoute String
  defaultFreq  String
  instructions String?
  isGlobal     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, class])
}

model ConsultationVersion {
  id             String       @id @default(cuid())
  consultationId String
  version        Int
  isFinal        Boolean      @default(false)
  content        Json
  hash           String?
  createdAt      DateTime     @default(now())
  consultation   Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)

  @@unique([consultationId, version])
  @@index([consultationId, isFinal])
}

model GlucoseLog {
  id         String   @id @default(cuid())
  tenantId   String
  patientId  String
  value      Int
  measuredAt DateTime
  notes      String?
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  patient    Patient  @relation(fields: [patientId], references: [id])

  @@unique([id, tenantId])
  @@index([tenantId, patientId, measuredAt])
}

model LabResult {
  id         String   @id @default(cuid())
  tenantId   String
  patientId  String
  examName   String
  value      Float
  unit       String?
  reference  String?
  resultDate DateTime
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  patient    Patient  @relation(fields: [patientId], references: [id])

  @@unique([id, tenantId])
  @@index([tenantId, patientId, resultDate])
}

model BioimpedanceExam {
  id           String   @id @default(cuid())
  tenantId     String
  patientId    String
  measuredAt   DateTime
  weightKg     Float?
  bodyFatPct   Float?
  muscleMassKg Float?
  metadata     Json?
  createdAt    DateTime @default(now())
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  patient      Patient  @relation(fields: [patientId], references: [id])

  @@unique([id, tenantId])
  @@index([tenantId, patientId, measuredAt])
}

model Appointment {
  id         String            @id @default(cuid())
  tenantId   String
  patientId  String
  date       DateTime
  time       String
  type       AppointmentType
  status     AppointmentStatus @default(AGENDADO)
  notes      String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  tenant     Tenant            @relation(fields: [tenantId], references: [id])
  patient    Patient           @relation(fields: [patientId], references: [id])

  @@unique([id, tenantId])
  @@index([tenantId, date, time])
  @@index([tenantId, patientId, date])
}
